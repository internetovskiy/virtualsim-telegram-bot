BOT_TOKEN=your_telegram_bot_token
# One id: 123456789  or  comma-separated: 111,222  or  JSON: [111,222]
ADMIN_IDS=

# Profile → API: enable access and copy key. All bot orders use this account balance.
VIRTUALSIM_API_KEY=
VIRTUALSIM_BASE_URL=https://virtualsim.io/api/v1

CRYPTOBOT_API_KEY=
CRYPTOBOT_BASE_URL=https://pay.crypt.bot/api

DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# Наценка на номера в процентах (0 = без наценки, 30 = +30%)
BOT_MARKUP_PERCENT=0

MIN_DEPOSIT=1.0
MAX_DEPOSIT=1000.0

CACHE_TTL=300
ACTIVATION_POLL_INTERVAL=5
ACTIVATION_TIMEOUT=600
